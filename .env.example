NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Requeridas solo para CoreStock Plus+ (suscripciones con Stripe).
# Estas 4 son secretas: nunca las pongas con prefijo NEXT_PUBLIC_ ni las subas al repo.
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PLUS=

# Requerida para el análisis de fotos de producto con IA (Google AI
# Studio / Gemini). Secreta: nunca la pongas con prefijo NEXT_PUBLIC_
# ni la subas al repo. Consíguela en https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
# Opcional: modelo de Gemini a usar (por defecto gemini-flash-latest).
GOOGLE_AI_MODEL=

# Requeridas para el Vendedor de WhatsApp con IA (Empleados IA) — la
# conexión real con WhatsApp Business API de Meta. Secretas: nunca las
# pongas con prefijo NEXT_PUBLIC_ ni las subas al repo.
# WHATSAPP_ACCESS_TOKEN: el token que da Meta en developers.facebook.com
#   (WhatsApp > Primeros pasos). El de esa pantalla es temporal (~24h);
#   para uno permanente, usa un Usuario del sistema en Configuración
#   empresarial de Meta.
# WHATSAPP_VERIFY_TOKEN: un valor que tú inventas — debe ser idéntico
#   acá y en el campo "Verify token" del webhook en el panel de Meta.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
